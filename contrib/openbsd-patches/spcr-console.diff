+/*
+ * Attach the console UART described by the ACPI SPCR table when it has no
+ * _HID device in the namespace (the AWS Graviton / ARM SBBR case).  The
+ * early console already runs on it (the bootloader synthesizes an FDT serial
+ * node from SPCR), but without a config(8)-matched driver there is no tty
+ * backing /dev/console.  Synthesize an attach so com(4)/pluart(4) can claim
+ * it from SPCR; the driver's own console check dedups against an _HID device
+ * that may already own the same base address.
+ */
+void
+acpi_foundspcr(struct acpi_softc *sc)
+{
+	struct device		*self = (struct device *)sc;
+	struct acpi_q		*entry;
+	struct acpi_spcr	*spcr = NULL;
+	struct acpi_attach_args	 aaa;
+
+	SIMPLEQ_FOREACH(entry, &sc->sc_tables, q_next) {
+		if (memcmp(((struct acpi_table_header *)entry->q_table)->
+		    signature, SPCR_SIG, 4) == 0) {
+			spcr = entry->q_table;
+			break;
+		}
+	}
+	if (spcr == NULL)
+		return;
+	if (spcr->base_address.address_space_id != GAS_SYSTEM_MEMORY ||
+	    spcr->base_address.address == 0)
+		return;
+
+	memset(&aaa, 0, sizeof(aaa));
+	aaa.aaa_iot = sc->sc_iot;
+	aaa.aaa_memt = sc->sc_memt;
+	aaa.aaa_node = sc->sc_root;
+	aaa.aaa_dev = "";
+	aaa.aaa_cdev = "";
+	aaa.aaa_naddr = 1;
+	aaa.aaa_addr[0] = spcr->base_address.address;
+	aaa.aaa_size[0] = 0x1000;
+	aaa.aaa_bst[0] = sc->sc_memt;
+	aaa.aaa_nirq = 1;
+	aaa.aaa_irq[0] = spcr->gsiv;
+	aaa.aaa_irq_flags[0] = 0;	/* GIC SPI, level-triggered, active-high */
+	aaa.aaa_spcr = spcr;
+	config_found(self, &aaa, acpi_print);
+}
